{
  "name": "voke",
  "version": "0.0.0",
  "description": "Deterministic MCP tool quality linter — MTQS v0.1 reference implementation",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "npm run build -w @voke-sh/voke",
    "voke": "npm run build && node packages/linter/dist/cli/index.js",
    "test": "vitest run",
    "test:spec": "vitest run tests/spec/",
    "typecheck": "tsc --build",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.6.0",
    "vitepress": "^1.6.4",
    "vitest": "4.1.8"
  }
}
