{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "composite": true,
    "declaration": true,
    "outDir": "dist",
    "rootDir": "src",
    "skipLibCheck": true,
    "types": ["node"],
    "paths": {
      "ajv/dist/2020": ["../../node_modules/ajv/dist/2020"],
      "ajv-formats": ["../../node_modules/ajv-formats/dist/index"]
    }
  },
  "references": [{ "path": "../core" }],
  "include": ["src/**/*.ts", "src/**/*.d.ts"]
}
