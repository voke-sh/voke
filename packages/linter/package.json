{
  "name": "@voke-sh/voke",
  "version": "0.1.1",
  "description": "Deterministic MCP tool quality linter — MTQS v0.1 reference implementation",
  "type": "module",
  "private": false,
  "license": "Apache-2.0",
  "homepage": "https://voke.sh",
  "repository": {
    "type": "git",
    "url": "https://github.com/voke-sh/voke.git",
    "directory": "packages/linter"
  },
  "keywords": [
    "mcp",
    "linter",
    "mtqs",
    "tool-quality",
    "ci"
  ],
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "bin": {
    "voke": "./dist/cli/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "~1.29.0",
    "ajv": "8.20.0",
    "ajv-formats": "3.0.1",
    "chalk": "5.6.2",
    "commander": "15.0.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@voke/core": "*",
    "tsup": "^8.5.1",
    "typescript": "^5.6.0"
  }
}
