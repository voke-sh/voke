{
  "name": "@voke/linter",
  "version": "0.0.0",
  "description": "Voke MTQS linter: rule engine, ingestion, canonicalization, and determinism layer",
  "type": "module",
  "private": true,
  "engines": { "node": ">=22" },
  "exports": { ".": { "types": "./src/index.ts", "import": "./src/index.ts" } },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@voke/core": "*",
    "@modelcontextprotocol/sdk": "~1.29.0",
    "ajv": "8.20.0",
    "ajv-formats": "3.0.1",
    "chalk": "5.6.2",
    "commander": "15.0.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.6.0"
  }
}
